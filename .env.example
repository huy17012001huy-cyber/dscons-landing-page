# URL kết nối cơ sở dữ liệu Supabase
VITE_SUPABASE_URL=https://your-supabase-project.supabase.co

# Khóa công khai của Supabase (Anon Key)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Khóa API Resend để phục vụ tính năng gửi mail tự động
RESEND_API_KEY=re_your_resend_api_key_here

# Khóa bảo mật kiểm thực Sepay Webhook (Tự đặt trùng khớp với Header Authorization cấu hình trên Sepay)
SEPAY_API_KEY=your_sepay_webhook_secret_here

# Cổng lắng nghe của API Server trên VPS
PORT=3000
